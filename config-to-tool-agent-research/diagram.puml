    +name: string
    +description: string
    +tools: DynamicToolFunctionSpec[]
  }
  interface AppServerToolCallback {
    +handle(item_tool_call): DynamicToolResponse
  }
  DynamicToolNamespace o-- DynamicToolFunctionSpec
  DynamicToolFunctionSpec ..> AppServerToolCallback : invocation sent to client
}

ClineAgentToolDefinition -[hidden]right-> GrokToolMetadata
ClineAgentTool -[hidden]down-> AnthropicClientToolContract
RegisteredGrokTool -[hidden]down-> DynamicToolNamespace
AnthropicClientExecutor -[hidden]right-> AppServerToolCallback
