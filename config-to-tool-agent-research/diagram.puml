@startuml tool_realization_pipeline
!pragma layout smetana
' Source evidence: coze-studio backend/domain/plugin/conf/load_plugin.go loadPluginProductMeta.
' Source evidence: coze-studio backend/domain/plugin/service/tool/invocation_http.go httpCallImpl.Do.
' Source evidence: qwen-code packages/core/src/tools/tool-registry.ts DiscoveredToolInvocation.execute.
' Source evidence: MCP schema/2025-11-25/schema.ts Tool, ListToolsResult, and CallToolRequest.
' Observed behavior: metadata becomes executable only when a runtime driver or remote server handles the call.
' Design reason: keep the model contract separate from implementation and deployment bindings.
title Tool manifest realization pipeline
skinparam componentStyle rectangle
skinparam shadowing false
skinparam backgroundColor white

actor Developer
rectangle "Control plane" {
  artifact "ToolManifest\nDescriptor + ImplementationRef" as Manifest
  component "Schema Validator" as Validator
  component "Manifest Compiler" as Compiler
  component "Driver Registry" as Registry
  component "Policy Compiler" as PolicyCompiler
}

rectangle "Runtime plane" {
  component "Model Tool Adapter" as ModelAdapter
  component "Policy Gate" as Gate
  component "Tool Executor" as Executor
  component "OpenAPI Driver" as OpenApiDriver
  component "MCP Proxy Driver" as McpDriver
  component "Command Driver" as CommandDriver
  component "Artifact Driver" as ArtifactDriver
  component "Workflow Driver" as WorkflowDriver
  component "Agent Proxy Driver" as AgentDriver
}

cloud "External API" as Api
node "MCP Server" as McpServer
node "Pinned Artifact" as Artifact
component "Workflow Runtime" as Workflow
component "Agent Runtime" as Agent

Developer --> Manifest
Manifest --> Validator
Validator --> Compiler
Compiler --> ModelAdapter : descriptor
Compiler --> Registry : implementation ref
Compiler --> PolicyCompiler : semantics and policy
PolicyCompiler --> Gate
ModelAdapter --> Gate : validated call
Gate --> Executor
Registry --> Executor : resolved driver
Executor --> OpenApiDriver
Executor --> McpDriver
Executor --> CommandDriver
Executor --> ArtifactDriver
Executor --> WorkflowDriver
Executor --> AgentDriver
OpenApiDriver --> Api
McpDriver --> McpServer
CommandDriver --> Artifact
ArtifactDriver --> Artifact
WorkflowDriver --> Workflow
AgentDriver --> Agent
@enduml

