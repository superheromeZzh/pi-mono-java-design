hide footbox
autonumber
title Skill Command End-to-End Invocation Sequence

participant "Client" as Client
participant "Agent Interaction\nUI" as UI
participant "Agent\nGW" as Gateway
participant "Agent\nRuntime" as Runtime
participant "Skills\nManager" as SkillsManager
participant "Resource\nManager" as ResourceManager
participant "Database" as Database
participant "Model\nManager" as ModelManager
participant "Tools\nManager" as ToolsManager

activate Client
Client -> UI: Submit /skill:review-pr 123
activate UI
UI -> Gateway: Submit Prompt
activate Gateway
Gateway -> ResourceManager: Load Agent configuration and session resources
activate ResourceManager
ResourceManager -> Database: Query resource data
activate Database
Database --> ResourceManager: Agent configuration and session
deactivate Database
ResourceManager --> Gateway: Configuration and context
deactivate ResourceManager
Gateway -> Runtime: prompt(context, text)
activate Runtime

Runtime -> SkillsManager: execute(text)
activate SkillsManager
SkillsManager -> SkillsManager: Parse name and arguments\nBuild resource query
SkillsManager -> ResourceManager: Read Skill resource
activate ResourceManager
ResourceManager -> Database: Query Skill by name
activate Database
Database --> ResourceManager: Skill data / not found
deactivate Database
ResourceManager --> SkillsManager: SkillResource / not found / error
deactivate ResourceManager
SkillsManager -> SkillsManager: Check Skill enabled state

alt Skill missing, disabled, or read failed
  SkillsManager --> Runtime: Return original text (fail-open)
else Skill enabled
  SkillsManager -> SkillsManager: Strip frontmatter\nBuild <skill> block\nAppend free-text args
  SkillsManager --> Runtime: expandedText
end
deactivate SkillsManager

par Prepare Model
  Runtime -> ModelManager: resolve(modelId)
  activate ModelManager
  ModelManager --> Runtime: Model
  deactivate ModelManager
else Prepare Tools
  Runtime -> ToolsManager: Get Tool definitions
  activate ToolsManager
  ToolsManager --> Runtime: definitions
  deactivate ToolsManager
end

Runtime -> ModelManager: invoke(expandedText, tools)
activate ModelManager
ModelManager --> Runtime: response / tool calls
deactivate ModelManager

loop Model returns Tool Call
  Runtime -> ToolsManager: execute(toolCall)
  activate ToolsManager
  ToolsManager --> Runtime: Tool result
  deactivate ToolsManager
  Runtime -> ModelManager: continue(Model, Tool result)
  activate ModelManager
  ModelManager --> Runtime: Model response / Tool calls
  deactivate ModelManager
end

Runtime --> Gateway: Agent response
deactivate Runtime
Gateway -> ResourceManager: Persist message resource
activate ResourceManager
ResourceManager -> Database: Save message
activate Database
Database --> ResourceManager: persisted
deactivate Database
ResourceManager --> Gateway: persisted
deactivate ResourceManager
Gateway --> UI: Agent response
deactivate Gateway
UI --> Client: Display response
deactivate UI
deactivate Client
@enduml

