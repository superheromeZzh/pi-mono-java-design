@startuml 04-unified-class-model
' pi source: packages/coding-agent/src/core/slash-commands.ts:13-40
' pi source: packages/coding-agent/src/modes/interactive/interactive-mode.ts:499-533,2541-2674
' Observed behavior: pi Built-in behavior consists of metadata, optional completion, workflow execution, and implicit runtime rules.
' Design reason: represent the complete Java command contract with one definition and no Built-in or Extension subtype.
' Java architecture change: shared and exclusive command concurrency is explicit because GUI entry points and async callbacks can overlap.
!theme plain
!pragma layout smetana
skinparam defaultFontName "SansSerif"
skinparam shadowing false
skinparam backgroundColor transparent
skinparam classAttributeIconSize 0
title Unified Java Command Class Model

interface CommandContributor {
  + commands(): List<CommandDefinition>
}

class CommandDefinition <<record>> {
  + String name
  + String description
  + CommandExecutionPolicy executionPolicy
  + Optional<CommandArgumentCompleter> argumentCompleter
  + CommandHandler handler
}

interface CommandHandler {
  + handle(invocation, context): CompletionStage<CommandExecutionResult>
}

interface CommandArgumentCompleter {
  + complete(prefix, context): CompletionStage<List<CommandCompletion>>
}

class CommandExecutionPolicy <<record>> {
  + CommandExecutionMode mode
  + CommandConcurrency concurrency
  + boolean userCancellable
  + Optional<Duration> timeout
}

enum CommandExecutionMode {
  IMMEDIATE
  REQUIRE_IDLE
  ABORT_AGENT_AND_RUN
  RUNTIME_TRANSITION
  SHUTDOWN
}

enum CommandConcurrency {
  SHARED
  EXCLUSIVE
}

note right of CommandConcurrency
  SHARED
  Can overlap with SHARED
  Conflicts with EXCLUSIVE

  EXCLUSIVE
  Conflicts with SHARED and EXCLUSIVE
  Only one holder
end note

class CommandInvocation <<record>> {
  + String rawInput
  + String name
  + String arguments
}

class CommandContext <<record>> {
  + CommandSession session
  + CommandInteraction interaction
  + CommandOutput output
  + CommandCancellation cancellation
}

class CommandExecutionResult <<record>> {
  + CommandOutcome outcome
  + Set<CommandRefreshHint> refreshHints
}

class CommandCatalogSnapshot <<immutable>>
class CommandInstaller
interface CommandRegistry
class CommandDispatcher
class CommandExecutionGate

