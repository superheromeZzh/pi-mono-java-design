title Extension Command 注册决策

start
:registerCommand(name, options);
if (Command name 合法?) then (否)
  :拒绝：INVALID_NAME;
  stop
else (是)
  if (description/handler 合法?) then (否)
    :拒绝：INVALID_OPTIONS;
    stop
  else (是)
    if (与内置命令同名?) then (是)
      :拒绝：BUILTIN_RESERVED;
      stop
    else (否)
      if (本次初始化重复?) then (是)
        :拒绝：DUPLICATE_IN_EXTENSION;
        stop
      else (否)
        if (其他 owner 已注册?) then (是)
          :拒绝：COMMAND_CONFLICT;
          stop
        else (否)
          :加入 Staging;
          if (Extension 全部命令校验完成?) then (否)
            :丢弃全部 Staging;
            stop
          else (是)
            :原子发布新 Snapshot;
            stop
          endif
        endif
      endif
    endif
  endif
endif
