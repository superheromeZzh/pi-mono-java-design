' Official source evidence: https://platform.claude.com/docs/en/managed-agents/agent-setup
' Official source evidence: https://platform.claude.com/docs/en/managed-agents/sessions
' Official source evidence: https://platform.claude.com/docs/en/managed-agents/events-and-streaming
' Observed behavior: a managed Agent is versioned configuration; a Session is created idle and a user message starts or resumes the loop.
' Design reason: keep the upstream lifecycle baseline separate from the target Java integration.
@startuml anthropic_managed_lifecycle
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam ArrowColor #3D8DFF
skinparam sequenceParticipantBorderColor #B8BCC4
skinparam sequenceParticipantBackgroundColor #EAF5FB
skinparam sequenceLifeLineBorderColor #B8BCC4

actor Client
control "Managed Agent API" as API
database "Agent vN\nversioned config" as Agent
participant Environment
database "Session\nstate: idle" as Session
participant "Agent loop" as Loop
participant "Resolved tools" as Tools

Client -> API: createAgent(config)
API -> Agent: persist immutable version
Client -> API: createEnvironment(resources)
API -> Environment: provision runtime context
Client -> API: createSession(agent_id, environment_id)
API -> Session: create durable idle state
Client -> API: user.message
API -> Loop: start or resume
loop until model stops
  Loop -> Tools: invoke tool
  Tools --> Loop: result
  Loop -> Session: append events and checkpoint
end
Loop --> Client: stream output events
Loop -> Session: state = idle
@enduml

