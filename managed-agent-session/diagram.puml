' Target-only architecture: AgentRuntimeRegistry, managed session factory, manager manifests, and SessionSnapshotV2 are new integration components.
' Java divergence: the current SessionConfig has only model, cwd, customPrompt, and mode, and AgentLoop executes AgentTool instances.
' Design reason: create isolated sessions with model tool schemas and a direct manager dispatcher while preserving exact manifests.
@startuml pi_session_creation
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam ArrowColor #3D8DFF
skinparam sequenceParticipantBorderColor #B8BCC4
skinparam sequenceParticipantBackgroundColor #EAF5FB
skinparam sequenceLifeLineBorderColor #B8BCC4

actor Client
participant "Managed Session Factory" as Factory
database "Agent Runtime Registry" as Registry
participant "Model Manager" as ModelManager
participant "Runtime Tool Catalog" as ToolCatalog
participant "ToolCallDispatcher" as Dispatcher
participant "Managed Prompt Builder" as Prompt
participant "pi-mono-java AgentSession" as JavaSession
participant "Provider Adapter" as Provider
participant "Tool Manager" as ToolManager
database "Session Manager JSONL" as History
database "Session Snapshot Store" as Store

Client -> Factory: createSession(agent_id, requested_version)
Factory -> Registry: get exact or latest runtime
Registry --> Factory: immutable runtime + manifest ids
Factory -> Store: reserve session id
Store --> Factory: session id
Factory -> ModelManager: select from pinned manifest
ModelManager --> Factory: concrete Model
Factory -> ToolCatalog: create from pinned descriptors
ToolCatalog --> Factory: model tools
Factory -> Dispatcher: bind catalog, manager, session context
Dispatcher --> Factory: direct execution entry
Factory -> Prompt: render base, skills, session context
Prompt --> Factory: final system prompt
Factory -> History: create or open session JSONL
History --> Factory: restored messages
Factory -> JavaSession: createManaged(model, prompt, model tools, dispatcher, messages)
JavaSession --> Factory: idle AgentSession
Factory -> Store: commit SessionSnapshotV2
Factory --> Client: session_id + status idle

Client -> JavaSession: prompt(message)
JavaSession -> Provider: Context(system, messages, tools)
Provider --> JavaSession: tool call(name, arguments)
JavaSession -> Dispatcher: dispatch(tool call)
Dispatcher -> ToolManager: invoke(manifest, binding, context, arguments)
ToolManager --> Dispatcher: result
Dispatcher --> JavaSession: ToolResultMessage
@enduml
