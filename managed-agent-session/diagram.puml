actor Client
control "Managed Agent API" as API
database "Agent vN\nversioned config" as Agent
participant Environment
database "Session\nstate: idle" as Session
participant "Agent loop" as Loop
participant "Resolved tools" as Tools

Client -> API: createAgent(config)
API -> Agent: persist immutable version
Client -> API: createEnvironment(resources)
API -> Environment: provision runtime context
Client -> API: createSession(agent_id, environment_id)
API -> Session: create durable idle state
Client -> API: user.message
API -> Loop: start or resume
loop until model stops
  Loop -> Tools: invoke tool
  Tools --> Loop: result
  Loop -> Session: append events and checkpoint
end
Loop --> Client: stream output events
Loop -> Session: state = idle
@enduml

