' Source evidence: modules/coding-agent-cli/src/main/java/com/campusclaw/codingagent/session/AgentSession.java initialize
' Source evidence: modules/coding-agent-cli/src/main/java/com/campusclaw/codingagent/mode/server/SessionPool.java createSessionWithPersistence
' Target-only architecture: AgentDeploymentPlan, AgentRuntimeBootstrap, AgentRuntimeRegistry, and readiness gating are new components.
' Observed behavior: current Java loading occurs inside each AgentSession initialization, not before container readiness.
' Java divergence: the target eagerly assembles every required runtime and never assembles one on the session request path.
' Design reason: fail startup on invalid required agents and keep session creation free of configuration and manager binding work.
@startuml agent_runtime_eager_startup
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam ArrowColor #3D8DFF
skinparam sequenceParticipantBorderColor #B8BCC4
skinparam sequenceParticipantBackgroundColor #EAF5FB
skinparam sequenceLifeLineBorderColor #B8BCC4

participant "Spring Container" as Container
database "Agent Deployment Plan" as Plan
database "Agent Config Repository" as ConfigRepo
participant "Agent Runtime Bootstrap" as Bootstrap
participant "Runtime Assembler" as Assembler
participant "Model Manager" as ModelManager
participant "Tool Manager" as ToolManager
participant "Skill Manager" as SkillManager
participant "Managed Prompt Builder" as Prompt
database "Agent Runtime Registry" as Registry
participant "Readiness Gate" as Readiness

Container -> Bootstrap: start
Bootstrap -> Readiness: REFUSING_TRAFFIC
Bootstrap -> Registry: begin BOOTSTRAPPING
Bootstrap -> Plan: list required agent id + version
Plan --> Bootstrap: pinned agent references
Bootstrap -> ConfigRepo: get exact configurations
ConfigRepo --> Bootstrap: versioned AgentConfig set

loop each required AgentConfig
  Bootstrap -> Assembler: assemble(config)
  Assembler -> ModelManager: resolve model manifest
  ModelManager --> Assembler: pinned model descriptors
  Assembler -> ToolManager: bind raw toolsets
  ToolManager --> Assembler: pinned tool manifest
  Assembler -> SkillManager: bind raw skill refs
  SkillManager --> Assembler: pinned skill manifest
  Assembler -> Prompt: compile static system + lists
  Prompt --> Assembler: static system prompt
  Assembler --> Bootstrap: immutable ResolvedAgentRuntime
  Bootstrap -> Registry: register while BOOTSTRAPPING
end

alt all required runtimes registered
  Bootstrap -> Registry: complete bootstrap and set READY
  Bootstrap -> Readiness: ACCEPTING_TRAFFIC
  Bootstrap --> Container: startup complete
else any required runtime fails
  Bootstrap -> Registry: set FAILED
  Bootstrap -> Readiness: remain REFUSING_TRAFFIC
  Bootstrap --> Container: fail startup
end
@enduml

