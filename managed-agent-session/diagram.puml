state "Preparing run" as PREPARING
state "Model streaming" as MODEL_STREAMING
state "Dispatching calls" as DISPATCHING
state "Invoking Tool Manager" as INVOKING_TOOL
state "Waiting for approval" as WAITING_APPROVAL
state "Resuming Tool Manager" as RESUMING_TOOL
state "Activating Skill Manager" as ACTIVATING_SKILL
state "Appending call results" as APPENDING_RESULTS
state "Checking follow-up" as CHECKING_FOLLOWUP
state "Completed" as COMPLETED
state "Failed" as FAILED
state "Cancelled" as CANCELLED

[*] --> PREPARING: session prompt
PREPARING --> MODEL_STREAMING: append user message
MODEL_STREAMING --> DISPATCHING: tool or skill calls
MODEL_STREAMING --> CHECKING_FOLLOWUP: normal stop without calls
MODEL_STREAMING --> FAILED: model manager failure
MODEL_STREAMING --> CANCELLED: cancellation
DISPATCHING --> INVOKING_TOOL: tool binding
DISPATCHING --> ACTIVATING_SKILL: skill binding
DISPATCHING --> APPENDING_RESULTS: unknown call
INVOKING_TOOL --> WAITING_APPROVAL: ApprovalRequired
INVOKING_TOOL --> APPENDING_RESULTS: completed, denied, or failed
WAITING_APPROVAL --> RESUMING_TOOL: user decision or expiry
WAITING_APPROVAL --> CANCELLED: cancellation
RESUMING_TOOL --> APPENDING_RESULTS: completed, denied, or failed
ACTIVATING_SKILL --> APPENDING_RESULTS: activated or failed
APPENDING_RESULTS --> DISPATCHING: more calls in batch
APPENDING_RESULTS --> MODEL_STREAMING: call batch complete
CHECKING_FOLLOWUP --> MODEL_STREAMING: follow-up queued
CHECKING_FOLLOWUP --> COMPLETED: no follow-up
COMPLETED --> [*]
FAILED --> [*]
CANCELLED --> [*]
@enduml

' Source evidence: modules/agent-core/src/main/java/com/campusclaw/agent/loop/AgentLoop.java runToolPhase
' Source evidence: modules/agent-core/src/main/java/com/campusclaw/agent/tool/ToolExecutionPipeline.java invokeTool
' Target-only architecture: Tool Manager bindings, approval records, resume tokens, and durable run checkpoints are not implemented in the Java baseline.
' Observed behavior: current Java tool execution validates and calls AgentTool.execute without a durable approval suspension protocol.
' Java divergence: permission is resolved and stored only by Tool Manager; Agent Runtime branches only on the returned invocation result type.
' Design reason: bind approval to the exact manifest, binding, call, argument hash, actor, and expiry to prevent policy bypass and replay.
@startuml tool_approval_resume_sequence
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam ArrowColor #3D8DFF
skinparam sequenceParticipantBorderColor #B8BCC4
skinparam sequenceParticipantBackgroundColor #EAF5FB
skinparam sequenceLifeLineBorderColor #B8BCC4

actor User
participant "Agent Runtime" as Runtime
participant "ToolCallDispatcher" as Dispatcher
participant "Tool Manager" as ToolManager
database "Binding Store" as BindingStore
database "Approval Store" as ApprovalStore
participant "Tool Executor" as Executor
database "Run Checkpoint Store" as CheckpointStore
participant "Model Manager" as ModelManager

Runtime -> Dispatcher: dispatch(tool call, run context)
Dispatcher -> ToolManager: invoke(manifest, binding, call, argument hash)
ToolManager -> BindingStore: load immutable binding and permission
BindingStore --> ToolManager: schema, executor, effective permission
ToolManager -> ToolManager: validate binding, actor, and arguments

alt permission allows immediate execution
  ToolManager -> Executor: execute validated request
  Executor --> ToolManager: normalized result
  ToolManager --> Dispatcher: Completed
  Dispatcher --> Runtime: ToolResultMessage
else permission requires approval
  ToolManager -> ApprovalStore: create bound approval record
  ApprovalStore --> ToolManager: approval id
  ToolManager --> Dispatcher: ApprovalRequired(approval id)
  Dispatcher --> Runtime: suspend result
  Runtime -> CheckpointStore: persist messages, call index, and approval id
  Runtime --> User: approval required event
  User -> Runtime: submit decision
  Runtime -> ToolManager: resume(approval id, decision)
  ToolManager -> ApprovalStore: atomically consume and validate record
  ApprovalStore --> ToolManager: bound invocation or rejection
  alt approved and valid
    ToolManager -> Executor: execute original bound invocation
    Executor --> ToolManager: normalized result
    ToolManager --> Runtime: Completed
  else denied, expired, or invalid
    ToolManager --> Runtime: Denied or Failed
  end
  Runtime -> CheckpointStore: append result and clear pending approval
end

Runtime -> ModelManager: continue with ToolResultMessage
@enduml
