@startuml managed_agents_resource_model
!pragma layout elk
title Anthropic Managed Agents Public Resource Model
top to bottom direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam nodesep 45
skinparam ranksep 55
skinparam ArrowColor #53657D
skinparam RectangleBorderColor #53657D
skinparam RectangleBackgroundColor #F7F9FC

' Source evidence:
' - https://platform.claude.com/docs/en/managed-agents/agent-setup
' - https://platform.claude.com/docs/en/managed-agents/sessions
' - https://platform.claude.com/docs/en/managed-agents/environments
' - https://platform.claude.com/docs/en/managed-agents/memory
' - https://platform.claude.com/docs/en/managed-agents/vaults
' - https://platform.claude.com/docs/en/managed-agents/multiagent-orchestration
' - https://platform.claude.com/docs/en/managed-agents/scheduled-deployments
' Observed behavior: an agent is versioned, an environment is not versioned, and each session receives an isolated sandbox.
' Observed behavior: vaults and memory stores are referenced by a session instead of being embedded in the reusable agent.
' Design reason: the layout centers the session and records only public relationships without inferring internal implementation.

rectangle "Skill\ncustom versions or Anthropic skill" as Skill #F3EEFF
rectangle "Agent\nversioned reusable configuration" as Agent #EAF2FF
rectangle "Environment\nunversioned sandbox configuration" as Environment #EAF2FF

rectangle "Vault\nworkspace credentials\n0..20 credentials per vault" as Vault #FFF4E6
rectangle "Session\nruntime state machine\nidle | running | rescheduling | terminated" as Session #E9F7EF
rectangle "Memory Store\nworkspace text documents\nmounted through resources" as MemoryStore #FFF4E6
rectangle "Deployment\nschedule plus session configuration" as Deployment #FDEEF4

rectangle "Agent snapshot\nresolved id, version, and session overrides" as Snapshot #F7F9FC
rectangle "Sandbox\nisolated per session" as Sandbox #F7F9FC
rectangle "Session thread\ncontext-isolated conversation" as Thread #F7F9FC
rectangle "Deployment run\nattempt with session_id or error" as DeploymentRun #F7F9FC
rectangle "Event stream\nuser events, system.message, agent events, session events, span events" as Event #F7F9FC

Skill -[hidden]right- Agent
Agent -[hidden]right- Environment
Vault -[hidden]right- Session
Session -[hidden]right- MemoryStore
MemoryStore -[hidden]right- Deployment
Snapshot -[hidden]right- Sandbox
Sandbox -[hidden]right- Thread
Thread -[hidden]right- DeploymentRun

Skill --> Agent : referenced by skills
Agent --> Session : resolve id and version
Environment --> Session : environment_id
Vault --> Session : vault_ids
MemoryStore --> Session : resources
Session *--> Snapshot : freezes
Session *--> Sandbox : provisions
Session *--> Thread : contains 1..*
Thread *--> Event : persists 0..*
Deployment --> Agent : agent configuration
Deployment --> Environment : environment configuration
Deployment *--> DeploymentRun : records 0..*
Deployment --> Session : creates scheduled sessions

@enduml

@startuml session_agent_creation_sequence
title Session Creation from a Versioned Agent Configuration

autonumber
hide footbox
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequenceArrowThickness 1
skinparam sequenceParticipantBorderColor #53657D
skinparam sequenceParticipantBackgroundColor #F7F9FC
skinparam ArrowColor #53657D
skinparam LifeLineBorderColor #90A0B5
skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center

' Source evidence:
' - https://platform.claude.com/docs/en/managed-agents/sessions
' - https://platform.claude.com/docs/en/api/beta/sessions/create
' - https://platform.claude.com/docs/en/managed-agents/environments
' - https://platform.claude.com/docs/en/managed-agents/tools
' - https://platform.claude.com/docs/en/managed-agents/mcp-connector
' - https://platform.claude.com/docs/en/managed-agents/skills
' Observed behavior: a session stores a resolved agent snapshot, provisions an isolated sandbox, starts idle, and begins work only after a user event is sent.
' Logical inference: component boundaries and the exact preparation order below are explanatory architecture, not claims about Anthropic internal implementation.
' Design reason: separate immutable agent version resolution from session-local overrides and runtime resource preparation so the resulting session is traceable.

actor Caller
boundary "Session API" as SessionAPI
database "Agent Store" as AgentStore
control "Config Resolver" as Resolver
database "Environment Store" as EnvStore
control "Sandbox Provisioner" as Sandbox
control "Resource and Skill Mounter" as Mounter
control "Vault and MCP Binder" as VaultBinder
control "Tool Registry" as ToolRegistry
database "Session Store" as SessionStore
boundary "Event API" as EventAPI
control "Agent Runtime" as Runtime
entity "Claude Model" as Model

Caller -> SessionAPI: POST /v1/sessions\nagent, environment_id, resources, vault_ids
activate SessionAPI

group Resolve the base agent version [Observed result]
  SessionAPI -> AgentStore: Resolve agent ID and requested version
  alt Agent ID string or version omitted
    AgentStore -> AgentStore: Select latest version at creation time
  else Explicit version
    AgentStore -> AgentStore: Select the requested immutable version
  end
  AgentStore --> SessionAPI: AgentVersion(id, version, configuration)
end

group Materialize the effective agent [Observed rules, inferred component]
  SessionAPI -> Resolver: Build effective configuration
  activate Resolver
  Resolver -> Resolver: Deep-copy the base AgentVersion

  loop model, system, tools, mcp_servers, skills
    alt Override field is omitted
      Resolver -> Resolver: Inherit the base field
    else Override is null or an empty list
      Resolver -> Resolver: Clear the field
    else Override has a value
      Resolver -> Resolver: Replace the complete field; do not merge
    end
  end

  Resolver -> Resolver: Require a model
  Resolver -> Resolver: Validate skills and read-tool compatibility
  Resolver -> Resolver: Validate MCP server and toolset references

  alt Effective configuration is invalid
    Resolver --> SessionAPI: Validation error
    deactivate Resolver
    SessionAPI --> Caller: 400 error
    deactivate SessionAPI
  else Effective configuration is valid
    Resolver -> Resolver: Resolve defaults and concrete references
    note right of Resolver
      Examples:
      - Normalize model and speed
      - Expand tool defaults
      - Resolve skill versions
      - Keep concrete subagent versions
    end note
    Resolver --> SessionAPI: ResolvedAgentSnapshot
    deactivate Resolver
  end
end

group Prepare the session runtime [Observed effects, inferred order]
  SessionAPI -> EnvStore: Read environment configuration
  EnvStore --> SessionAPI: Packages, networking, runtime settings

  SessionAPI -> Sandbox: Provision a fresh isolated sandbox
  activate Sandbox
  Sandbox -> Sandbox: Install or attach environment packages
  Sandbox -> Sandbox: Apply networking policy
  Sandbox --> SessionAPI: Sandbox handle
  deactivate Sandbox

  SessionAPI -> Mounter: Mount session resources
  activate Mounter
  opt Files or repositories are attached
    Mounter -> Mounter: Mount files and clone requested revisions
  end
  opt Memory stores are attached
    Mounter -> Mounter: Mount stores and prepare memory instructions
  end
  Mounter -> Mounter: Mount resolved agent skills
  Mounter --> SessionAPI: Mounted resource descriptors
  deactivate Mounter

  SessionAPI -> VaultBinder: Bind vault credentials to MCP server URLs
  activate VaultBinder
  VaultBinder -> VaultBinder: Prepare MCP connections without storing secrets in the agent
  VaultBinder --> SessionAPI: Session-local MCP bindings
  deactivate VaultBinder

  SessionAPI -> ToolRegistry: Register effective tools and permission policies
  activate ToolRegistry
  ToolRegistry -> ToolRegistry: Register built-in, MCP, and custom tool contracts
  ToolRegistry --> SessionAPI: Effective tool registry
  deactivate ToolRegistry
end

group Persist the session boundary [Observed result]
  SessionAPI -> SessionStore: Create session with resolved agent snapshot
  activate SessionStore
  SessionStore -> SessionStore: Store base agent ID and concrete version
  SessionStore -> SessionStore: Store environment, resources, vault IDs, and metadata
  SessionStore -> SessionStore: Initialize primary thread and status = idle
  SessionStore --> SessionAPI: Session(id, agent snapshot, status = idle)
  deactivate SessionStore
  note over SessionAPI, SessionStore
    POST /v1/sessions provisions the runtime boundary.
    It does not send task work to the model.
  end note
end

SessionAPI --> Caller: 200 Session
deactivate SessionAPI

== Work starts in a separate event request ==

Caller -> EventAPI: POST /v1/sessions/{id}/events\nuser.message
activate EventAPI
EventAPI -> SessionStore: Load session and resolved snapshot
SessionStore --> EventAPI: Session status = idle
EventAPI -> Runtime: Start agent turn with snapshot and user event
activate Runtime
Runtime -> SessionStore: Set status = running
Runtime -> Model: Invoke resolved model with system, history, and tools
activate Model
Model --> Runtime: Message or tool request
deactivate Model
Runtime --> EventAPI: Stream agent and session events
deactivate Runtime
EventAPI --> Caller: Event stream or acknowledgement
deactivate EventAPI

@enduml

@startuml managed_agent_configuration_model
!pragma layout smetana
title Anthropic Managed Agent Public Configuration Model
top to bottom direction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam nodesep 40
skinparam ranksep 45
skinparam classAttributeIconSize 0
skinparam ArrowColor #53657D
skinparam ClassBorderColor #53657D
skinparam ClassBackgroundColor #F7F9FC

' Source evidence:
' - https://platform.claude.com/docs/en/managed-agents/agent-setup
' - https://platform.claude.com/docs/en/managed-agents/tools
' - https://platform.claude.com/docs/en/managed-agents/mcp-connector
' - https://platform.claude.com/docs/en/managed-agents/skills
' - https://platform.claude.com/docs/en/managed-agents/multiagent-orchestration
' Observed behavior: tools is a tagged union of the managed agent toolset, MCP toolsets, and custom tool contracts.
' Observed behavior: an MCP server declaration and its MCP toolset reference must match by name.
' Design reason: field names and discriminator values follow the public request and response contract.

class ManagedAgent <<public API resource>> {
  id: String
  type: agent
  version: Integer
  name: String
  description: String?
  system: String?
  metadata: Map<String, String>
  created_at: Timestamp
  updated_at: Timestamp
  archived_at: Timestamp?
}

class ModelConfig {
  id: String
  speed: standard | fast
}

abstract class ToolDefinition <<tagged union>> {
  type: String
}

class AgentToolset {
  type: agent_toolset_20260401
  default_config: ToolConfig?
  configs: ToolConfig[]
}

class McpToolset {
  type: mcp_toolset
  mcp_server_name: String
  default_config: ToolConfig?
  configs: ToolConfig[]
}

class CustomTool {
  type: custom
  name: String
  description: String
  input_schema: JSONSchema
}

class ToolConfig {
  name: String?
  enabled: Boolean?
  permission_policy: PermissionPolicy?
}

class PermissionPolicy <<tagged union>> {
  type: always_allow | always_ask
}

class McpServer {
  type: url
  name: String
  url: String
}

class SkillReference {
  type: anthropic | custom
  skill_id: String
  version: String?
}

class MultiagentCoordinator {
  type: coordinator
  agents: AgentReference[]
}

class AgentReference <<tagged union>> {
  type: agent | self
  id: String?
  version: Integer?
}

ManagedAgent *-- "1" ModelConfig : model
ManagedAgent *-- "0..*" ToolDefinition : tools
ToolDefinition <|-- AgentToolset
ToolDefinition <|-- McpToolset
ToolDefinition <|-- CustomTool
AgentToolset *-- "0..*" ToolConfig : configures
McpToolset *-- "0..*" ToolConfig : configures
ToolConfig o-- "0..1" PermissionPolicy
ManagedAgent *-- "0..20" McpServer : mcp_servers
McpToolset --> "1" McpServer : matches by name
ManagedAgent *-- "0..*" SkillReference : skills
ManagedAgent *-- "0..1" MultiagentCoordinator : multiagent
MultiagentCoordinator *-- "1..20" AgentReference : roster

note right of ManagedAgent
Create requires name and model.
Update requires the current version.
Configuration changes create a new version.
end note

note right of AgentToolset
Built-in names:
bash, read, write, edit,
glob, grep, web_fetch, web_search
end note

note left of ToolDefinition
Maximum 128 effective tools
across all toolsets.
end note

note right of SkillReference
The session-wide limit is 500 skills
across every agent in the session.
end note

@enduml

@startuml managed_agents_tool_execution_model
title Anthropic Managed Agents Public Tool Execution Boundaries

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam sequenceArrowThickness 1
skinparam sequenceParticipantBorderColor #53657D
skinparam sequenceParticipantBackgroundColor #F7F9FC
skinparam ArrowColor #53657D
skinparam LifeLineBorderColor #90A0B5

' Source evidence:
' - https://platform.claude.com/docs/en/managed-agents/tools
' - https://platform.claude.com/docs/en/managed-agents/mcp-connector
' - https://platform.claude.com/docs/en/managed-agents/events-and-streaming
' - https://platform.claude.com/docs/en/managed-agents/vaults
' Observed behavior: built-in tools run in the session sandbox, MCP tools run on the declared remote server, and custom tools run in the client application.
' Observed behavior: always_ask pauses the session for user.tool_confirmation; custom calls pause for user.custom_tool_result.
' Design reason: the sequence separates declaration from runtime ownership and does not imply a shared executable format.

actor User
participant "Client application" as Client
participant "Managed Agents API" as API
participant "Session runtime" as Runtime
participant "Session sandbox" as Sandbox
participant "Vault service" as Vault
participant "Remote MCP server" as MCP

User -> Client : submit task
Client -> API : create session(agent, environment_id, vault_ids)
API -> Runtime : provision resolved agent snapshot
Client -> API : user.message
API -> Runtime : start work

group Built-in agent tool
  Runtime -> API : agent.tool_use
  opt permission_policy = always_ask
    API -->> Client : session.status_idle(requires_action)
    Client -> API : user.tool_confirmation(allow | deny)
  end
  API -> Sandbox : execute built-in tool
  Sandbox --> API : tool result
  API --> Runtime : continue with result
end

group MCP tool
  Runtime -> API : agent.mcp_tool_use
  opt permission_policy = always_ask
    API -->> Client : session.status_idle(requires_action)
    Client -> API : user.tool_confirmation(allow | deny)
  end
  API -> Vault : resolve credential by server URL
  Vault --> API : runtime credential
  API -> MCP : invoke MCP tool
  MCP --> API : MCP result
  API --> Runtime : continue with result
end

group Custom tool
  Runtime -> API : agent.custom_tool_use(name, input)
  API -->> Client : event plus session.status_idle(requires_action)
  Client -> Client : execute application code
  Client -> API : user.custom_tool_result(custom_tool_use_id, content)
  API -> Runtime : resume when all blocking calls resolve
end

Runtime --> API : agent.message and session status
API -->> Client : event stream
Client --> User : result

@enduml
